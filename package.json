{
  "name": "tu-vi-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:e2e": "next dev --webpack -p 4000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node scripts/seed-production.mjs",
    "db:setup": "npm run db:deploy && npm run db:seed && npm run pseo:seed",
    "analyze": "ANALYZE=true next build",
    "perf:smoke": "node scripts/smoke-performance.mjs",
    "seo:autopilot": "node scripts/seo/seo-autopilot-plan.mjs --json",
    "seo:autopilot:execute": "node scripts/seo/seo-autopilot-execute.mjs",
    "seo:autopilot:publisher": "node scripts/seo/seo-autopilot-execute.mjs --articles 1 --summary-json",
    "seo:autopilot:cluster": "node scripts/seo/seo-autopilot-execute.mjs --cluster --articles 5 --summary-json",
    "seo:lighthouse": "npx @lhci/cli@0.15.x autorun --config=./lighthouserc.cjs",
    "seo:autopilot:snapshot": "node scripts/seo/seo-autopilot-snapshot.mjs --json",
    "traffic:autopilot": "node scripts/traffic/traffic-autopilot.mjs",
    "smoke:google-ads": "node scripts/smoke-google-ads.mjs",
    "smoke:payos": "node scripts/smoke-payos-checkout.mjs",
    "pseo:seed": "node --experimental-strip-types scripts/seed-pseo.ts",
    "seed:interpretations": "node --experimental-strip-types scripts/seed-interpretations.ts",
    "pseo:generate": "node --experimental-strip-types scripts/generate-pseo.ts",
    "env:check:production": "node scripts/check-production-env.mjs",
    "ship": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-production.ps1",
    "agent:headroom:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/headroom-agent.ps1 doctor",
    "agent:headroom:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/headroom-agent.ps1 smoke",
    "agent:headroom:stats": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/headroom-agent.ps1 stats",
    "agent:headroom:claude": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/headroom-agent.ps1 claude"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "vitest": "^4.1.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright-core": "^1.60.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
